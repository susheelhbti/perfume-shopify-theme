<header class="hero" data-hero>
  <div class="hero-photo-bg" aria-hidden="true" style="{% if section.settings.background_image %}background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');{% endif %}"></div>
  <div class="hero-photo-overlay" aria-hidden="true"></div>
  <div id="hero-particles" class="hero-particles" aria-hidden="true"></div>
  <div class="hero-bg-logo" aria-hidden="true"><span>{{ section.settings.watermark_text | default: shop.name }}</span></div>

  <div class="container hero-grid">
    <div class="hero-copy reveal">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1>{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="lede">{{ section.settings.body }}</p>
      {%- endif -%}
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_url | default: '#collection' }}" class="btn btn-gold">{{ section.settings.cta_text }}</a>
      {%- endif -%}
    </div>

   

    {%- if section.blocks.size > 0 -%}
      <div class="hero-gallery reveal">
        {%- for block in section.blocks -%}
          {%- if block.type == 'gallery_image' -%}
            <div class="hero-gallery-item"
                 style="{% if block.settings.image %}background-image: url('{{ block.settings.image | image_url: width: 700 }}');{% endif %}"
                 role="img" aria-label="{{ block.settings.alt | default: shop.name | escape }}"
                 {{ block.shopify_attributes }}></div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  {%- if section.settings.show_scroll_cue -%}
    <div class="scroll-cue"><span class="line"></span>Scroll</div>
  {%- endif -%}
</header>




{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background photo",
      "info": "Sits behind the gold/black gradient overlay, desaturated automatically"
    },
    {
      "type": "text",
      "id": "watermark_text",
      "label": "Background watermark text",
      "info": "Large faint text behind the hero copy. Defaults to store name."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "NOXR — Eau de Parfum Oils"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Every memory has a scent"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Luxury perfume oils crafted to capture moments, memories and emotions."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "show_bottle",
      "label": "Show 3D bottle visual",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_scroll_cue",
      "label": "Show scroll cue",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "gallery_image",
      "name": "Gallery image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "gallery_image" },
        { "type": "gallery_image" },
        { "type": "gallery_image" },
        { "type": "gallery_image" }
      ]
    }
  ]
}
{% endschema %}
