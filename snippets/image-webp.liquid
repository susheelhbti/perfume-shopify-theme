{%- comment -%}
  Renders an image with WebP support via picture element
  Usage: {% render 'image-webp', image: product.featured_image, alt: product.title, class: 'my-class' %}
{%- endcomment -%}

<picture>
  {%- if image -%}
    <source 
      srcset="{{ image | image_url: width: 800, format: 'webp' }} 800w,
              {{ image | image_url: width: 1200, format: 'webp' }} 1200w,
              {{ image | image_url: width: 1600, format: 'webp' }} 1600w"
      type="image/webp"
      sizes="(min-width: 1024px) 33vw, 50vw"
    >
    <img
      src="{{ image | image_url: width: 800 }}"
      srcset="{{ image | image_url: width: 800 }} 800w,
              {{ image | image_url: width: 1200 }} 1200w,
              {{ image | image_url: width: 1600 }} 1600w"
      sizes="(min-width: 1024px) 33vw, 50vw"
      alt="{{ alt | escape }}"
      loading="lazy"
      class="{{ class }}"
      width="{{ image.width }}"
      height="{{ image.height }}"
    >
  {%- else -%}
    <img src="{{ placeholder | default: 'product-1' | placeholder_svg_tag }}" alt="{{ alt | escape }}" class="{{ class }}">
  {%- endif -%}
</picture>