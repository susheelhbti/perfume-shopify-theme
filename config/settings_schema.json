[
  {
    "name": "theme_info",
    "theme_name": "NOXR Minimal",
    "theme_version": "1.0.0",
    "theme_author": "NOXR",
    "theme_documentation_url": "https://example.com",
    "theme_support_url": "https://example.com/support"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_bg",
        "label": "Background",
        "default": "#050505"
      },
      {
        "type": "color",
        "id": "color_bg_raised",
        "label": "Background (raised panels)",
        "default": "#0B0B0B"
      },
      {
        "type": "color",
        "id": "color_text_primary",
        "label": "Text (primary)",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_text_secondary",
        "label": "Text (secondary)",
        "default": "#BDBDBD"
      },
      {
        "type": "color",
        "id": "color_text_tertiary",
        "label": "Text (tertiary)",
        "default": "#6F6F6F"
      },
      {
        "type": "color",
        "id": "color_gold",
        "label": "Gold (accent)",
        "default": "#C6A56B"
      },
      {
        "type": "color",
        "id": "color_gold_dim",
        "label": "Gold (dim)",
        "default": "#8A7350"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Display font",
        "default": "fraunces_n6",
        "info": "Used for headings, prices, and the eyebrow signature. Fraunces is tuned for large display sizes — avoid setting this to your body font."
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "inter_n4",
        "info": "Used for paragraphs, navigation, buttons, and form fields"
      }
    ]
  },
  {
    "name": "Collections",
    "settings": [
      {
        "type": "header",
        "content": "Homepage collection panels"
      },
      {
        "type": "paragraph",
        "content": "Used by the Collections section to map the three editorial tiers to real Shopify collections."
      },
      {
        "type": "collection",
        "id": "collection_classic",
        "label": "Classic collection"
      },
      {
        "type": "collection",
        "id": "collection_signature",
        "label": "Signature collection"
      },
      {
        "type": "collection",
        "id": "collection_inspired",
        "label": "Inspired collection"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "label": "Page width",
        "min": 1000,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "default": 1280
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "free_shipping_enable",
        "label": "Show free shipping progress bar",
        "default": true
      },
      {
        "type": "number",
        "id": "free_shipping_threshold",
        "label": "Free shipping threshold ($)",
        "default": 150
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "header",
        "content": "Social accounts"
      },
      { "type": "text", "id": "social_instagram_link", "label": "Instagram" },
      { "type": "text", "id": "social_facebook_link", "label": "Facebook" },
      { "type": "text", "id": "social_pinterest_link", "label": "Pinterest" },
      { "type": "text", "id": "social_youtube_link", "label": "YouTube" },
      { "type": "text", "id": "social_tiktok_link", "label": "TikTok" }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "Will be scaled down to 32 x 32px"
      }
    ]
  }
]
