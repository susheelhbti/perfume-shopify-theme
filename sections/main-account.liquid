<div class="legal-wrapper account-page" {{ section.shopify_attributes }}>
  <div class="account-header">
    <div>
      <span class="legal-eyebrow">My Account</span>
      <h1 class="legal-title">Welcome, {{ customer.first_name | default: customer.name }}</h1>
    </div>
    <div class="account-header-actions">
      <a href="{{ routes.account_addresses_url }}" class="btn btn-outline">Addresses</a>
      <a href="{{ routes.account_logout_url }}" class="btn btn-outline">Log Out</a>
    </div>
  </div>

  <div class="legal-section">
    <h2>Order History</h2>

    {%- if customer.orders.size == 0 -%}
      <p style="color: rgba(255,255,255,0.4);">You haven't placed any orders yet.</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn" style="margin-top: 1rem;">Start Shopping</a>
    {%- else -%}
      <table class="account-orders-table">
        <thead>
          <tr>
            <th>Order</th>
            <th>Date</th>
            <th>Payment Status</th>
            <th>Fulfillment Status</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          {%- for order in customer.orders -%}
            <tr>
              <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
              <td>{{ order.created_at | date: '%B %-d, %Y' }}</td>
              <td>{{ order.financial_status_label }}</td>
              <td>{{ order.fulfillment_status_label }}</td>
              <td>{{ order.total_price | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    {%- endif -%}
  </div>

  {%- if customer.default_address -%}
    <div class="legal-section">
      <h2>Default Address</h2>
      <p>
        {{ customer.default_address.name }}<br>
        {{ customer.default_address.address1 }}{% if customer.default_address.address2 != blank %}, {{ customer.default_address.address2 }}{% endif %}<br>
        {{ customer.default_address.city }}, {{ customer.default_address.province_code }} {{ customer.default_address.zip }}<br>
        {{ customer.default_address.country }}
      </p>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Account",
  "settings": []
}
{% endschema %}
