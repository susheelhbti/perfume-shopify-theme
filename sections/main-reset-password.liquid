<div class="legal-wrapper auth-page" {{ section.shopify_attributes }}>
  <span class="legal-eyebrow">Account</span>
  <h1 class="legal-title">Reset Your Password</h1>
  <p style="margin-top: 0.8rem;">Enter a new password for {{ customer.email | default: 'your account' }}.</p>

  <div class="auth-form-wrap">
    {%- form 'reset_customer_password' -%}
      {%- if form.errors -%}
        <div class="auth-error">{{ form.errors | default_errors }}</div>
      {%- endif -%}

      <label for="ResetPassword">New password</label>
      <input type="password" name="customer[password]" id="ResetPassword" autocomplete="new-password" required>

      <label for="ResetPasswordConfirm">Confirm new password</label>
      <input type="password" name="customer[password_confirmation]" id="ResetPasswordConfirm" autocomplete="new-password" required>

      <button type="submit" class="btn btn-gold btn-block">Reset Password</button>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Reset password",
  "settings": []
}
{% endschema %}
