<section class="reveal" {{ section.shopify_attributes }}>
  {{ 'testimonials.css' | asset_url | stylesheet_tag }}
  <div class="container">
    <div class="section-head">
      <div>
        {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      </div>
    </div>
    <div class="reviews-row">
      {%- for block in section.blocks -%}
        <div class="review-card" {{ block.shopify_attributes }}>
          <div class="review-stars">
            {%- for i in (1..5) -%}{% if i <= block.settings.rating %}&#9733;{% else %}&#9734;{% endif %}{%- endfor -%}
          </div>
          <p class="review-quote">{{ block.settings.quote }}</p>
          <div class="review-name">{{ block.settings.author }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reviews",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "In Their Words"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Worn, not just bought"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Midnight Oud doesn't fade by evening. It just settles into something warmer."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Aarav M. — Mumbai"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        { "type": "review" },
        {
          "type": "review",
          "settings": { "quote": "First oil perfume that's actually made me switch from sprays for good.", "author": "Sana K. — Delhi" }
        },
        {
          "type": "review",
          "settings": { "quote": "Velvet Amber smells expensive without trying too hard. Exactly what I wanted.", "author": "Rohan D. — Bengaluru" }
        }
      ]
    }
  ]
}
{% endschema %}
