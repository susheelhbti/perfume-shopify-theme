{% comment %}
  ============================================================
  SECTION: Three Collections (Full Card Images + Content Overlay)
  ============================================================
  Animations included:
  - Staggered card reveals with directional slide
  - Per-element hover sequencing (tier → title → desc → price → CTA)
  - Floating collection numbers
  - Signature card breathing glow
  - Shimmer light-sweep on hover
  - Animated top/bottom border lines
  - View All underline draw-in
  - Heading word-by-word reveal
  - Eyebrow letter-spacing expand
  ============================================================
{% endcomment %}

{% liquid
  assign heading = section.settings.heading | default: 'Three ways to be remembered'
  assign subheading = section.settings.subheading | default: 'The Collections'
  assign button_text = section.settings.button_text | default: 'Discover'
  assign bg_color = section.settings.background_color | default: '#050505'
  assign text_color = section.settings.text_color | default: '#ffffff'
  assign accent_color = section.settings.accent_color | default: '#c6a56b'
  
  assign collection_1 = section.settings.collection_1
  assign collection_2 = section.settings.collection_2
  assign collection_3 = section.settings.collection_3
  
  assign collection_1_tier = section.settings.collection_1_tier | default: 'Entry Luxury'
  assign collection_2_tier = section.settings.collection_2_tier | default: 'Premium · House Focus'
  assign collection_3_tier = section.settings.collection_3_tier | default: 'Icon Series'
  
  assign collection_1_tagline = section.settings.collection_1_tagline | default: 'Everyday luxury. Clean, versatile fragrances for every occasion.'
  assign collection_2_tagline = section.settings.collection_2_tagline | default: 'Rare ingredients. Deeper character. Longer lasting compositions.'
  assign collection_3_tagline = section.settings.collection_3_tagline | default: 'Inspired by globally celebrated fragrances, reimagined with NOXR craftsmanship.'
  
  assign collection_1_price = section.settings.collection_1_price | default: '₹999 — ₹1,999'
  assign collection_2_price = section.settings.collection_2_price | default: '₹2,499 — ₹4,999'
  assign collection_3_price = section.settings.collection_3_price | default: '₹2,499 — ₹4,999'
  
  assign collection_1_is_signature = section.settings.collection_1_is_signature | default: false
  assign collection_2_is_signature = section.settings.collection_2_is_signature | default: true
  assign collection_3_is_signature = section.settings.collection_3_is_signature | default: false
  
  assign image_1 = section.settings.image_1
  assign image_2 = section.settings.image_2
  assign image_3 = section.settings.image_3
%}

<style>
  #shopify-section-{{ section.id }} .collections-section {
    background: {{ bg_color }};
    color: {{ text_color }};
    padding: 80px 0;
  }
  
  #shopify-section-{{ section.id }} .collections-section .eyebrow {
    color: {{ accent_color }};
  }
  
  #shopify-section-{{ section.id }} .collections-section .collection-card {
    background: {{ bg_color }};
  }
  
  #shopify-section-{{ section.id }} .collections-section .collection-price,
  #shopify-section-{{ section.id }} .collections-section .collection-link {
    color: {{ accent_color }};
  }
  
  #shopify-section-{{ section.id }} .collections-section .collection-link {
    border-color: {{ accent_color }}30;
  }
  
  #shopify-section-{{ section.id }} .collections-section .collection-link:hover {
    color: {{ accent_color }};
    border-color: {{ accent_color }};
  }
  
  #shopify-section-{{ section.id }} .collections-section .collection-card .collection-num {
    color: rgba(255,255,255,0.4);
  }
  
  #shopify-section-{{ section.id }} .collections-section .collection-card::before {
    background: var(--card-tint, radial-gradient(circle at 50% 20%, rgba(255,255,255,0.05), transparent 60%));
  }
  
  #shopify-section-{{ section.id }} .collections-section .collection-card::after {
    background: radial-gradient(circle at var(--mx, 50%) var(--my, 30%), rgba(255,255,255,0.07), transparent 45%);
  }
  
  #shopify-section-{{ section.id }} .collections-section .section-head .view-all {
    color: var(--text-secondary, #bdbdbd);
  }
  
  #shopify-section-{{ section.id }} .collections-section .section-head .view-all:hover {
    color: {{ accent_color }};
  }

  /* ---- Keyframes ---- */
  @keyframes sig-breathe {
    0%, 100% { box-shadow: inset 0 0 60px rgba(198,165,107,0.0), 0 0 0 rgba(198,165,107,0); }
    50% { box-shadow: inset 0 0 80px rgba(198,165,107,0.06), 0 0 40px rgba(198,165,107,0.04); }
  }
  @keyframes num-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  @keyframes shimmer {
    0% { transform: translateX(-120%) skewX(-15deg); }
    100% { transform: translateX(220%) skewX(-15deg); }
  }
  @keyframes line-draw-top {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }
  @keyframes line-draw-bottom {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }
  @keyframes letter-expand {
    from { letter-spacing: 0.05em; opacity: 0; }
    to { letter-spacing: 0.28em; opacity: 1; }
  }
  @keyframes word-up {
    from { transform: translateY(110%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  @keyframes underline-draw {
    from { opacity: 0; transform: scaleX(0); transform-origin: left; }
    to { opacity: 1; transform: scaleX(1); transform-origin: left; }
  }
  @keyframes card-in-left {
    from { opacity: 0; transform: translateX(-60px) translateY(20px); }
    to { opacity: 1; transform: translateX(0) translateY(0); }
  }
  @keyframes card-in-up {
    from { opacity: 0; transform: translateY(60px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes card-in-right {
    from { opacity: 0; transform: translateX(60px) translateY(20px); }
    to { opacity: 1; transform: translateX(0) translateY(0); }
  }
  @keyframes elem-rise {
    from { transform: translateY(14px); opacity: 0.4; }
    to { transform: translateY(0); opacity: 1; }
  }

  /* ============================================================
     Base Variables
     ============================================================ */
  #shopify-section-{{ section.id }} {
    --bg: #050505;
    --bg-raised: #0b0b0b;
    --text-primary: #ffffff;
    --text-secondary: #bdbdbd;
    --text-tertiary: #6f6f6f;
    --gold: #c6a56b;
    --gold-dim: #8a7350;
    --hairline: rgba(255, 255, 255, 0.08);
    --hairline-gold: rgba(198, 165, 107, 0.35);
    --font-display: "Cormorant Garamond", serif;
    --font-body: "Inter", sans-serif;
    --container: 1280px;
    --gutter: clamp(24px, 5vw, 64px);
    --ease: cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ============================================================
     Container
     ============================================================ */
  #shopify-section-{{ section.id }} .container {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  /* ============================================================
     Section Head
     ============================================================ */
  #shopify-section-{{ section.id }} .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
    margin-bottom: 64px;
  }

  #shopify-section-{{ section.id }} .section-head .eyebrow {
    display: block;
    margin-bottom: 18px;
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 400;
    opacity: 0;
  }

  #shopify-section-{{ section.id }} .section-head h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 4.2vw, 56px);
    font-weight: 400;
    letter-spacing: 0.01em;
    line-height: 1.05;
    color: var(--text-primary);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .section-head h2 .word {
    display: inline-block;
    overflow: hidden;
    vertical-align: bottom;
    padding-bottom: 2px;
  }
  #shopify-section-{{ section.id }} .section-head h2 .word-inner {
    display: inline-block;
    transform: translateY(110%);
    opacity: 0;
  }

  #shopify-section-{{ section.id }} .section-head .view-all {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding-bottom: 6px;
    white-space: nowrap;
    opacity: 0;
    position: relative;
    text-decoration: none;
    border-bottom: 1px solid var(--hairline-gold);
    transition: color 0.3s var(--ease), border-color 0.3s var(--ease);
  }
  #shopify-section-{{ section.id }} .section-head .view-all::after {
    content: "";
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 1px;
    background: {{ accent_color }};
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s var(--ease);
  }
  #shopify-section-{{ section.id }} .section-head .view-all:hover::after {
    transform: scaleX(1);
  }

  #shopify-section-{{ section.id }} .section-head.is-visible .eyebrow {
    animation: letter-expand 0.9s var(--ease) 0.1s forwards;
  }
  #shopify-section-{{ section.id }} .section-head.is-visible .word-inner {
    animation: word-up 0.8s var(--ease) forwards;
  }
  #shopify-section-{{ section.id }} .section-head.is-visible .view-all {
    animation: underline-draw 0.6s var(--ease) 0.8s forwards;
  }

  @media (max-width: 700px) {
    #shopify-section-{{ section.id }} .section-head {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
  }

  /* ============================================================
     Collections Grid
     ============================================================ */
  #shopify-section-{{ section.id }} .collections-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.3fr 0.85fr;
    gap: 1px;
    background: var(--hairline);
    border: 1px solid var(--hairline);
    perspective: 1600px;
  }

  /* ============================================================
     Collection Card - Full Image Background
     ============================================================ */
  #shopify-section-{{ section.id }} .collection-card {
    background: var(--bg);
    position: relative;
    min-height: 640px;
    padding: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    transition: background 0.5s var(--ease), transform 0.5s var(--ease), box-shadow 0.5s var(--ease);
    transform-style: preserve-3d;
    transform: rotateX(var(--ry, 0deg)) rotateY(var(--rx, 0deg)) translateZ(0px);
    will-change: transform;
    text-decoration: none;
    color: var(--text-primary);
    opacity: 0;
  }

  #shopify-section-{{ section.id }} .collection-card.is-signature {
    min-height: 720px;
  }

  /* Staggered entrance */
  #shopify-section-{{ section.id }} .collection-card[data-card="0"].is-entering {
    animation: card-in-left 0.9s var(--ease) 0.2s forwards;
  }
  #shopify-section-{{ section.id }} .collection-card[data-card="1"].is-entering {
    animation: card-in-up 0.9s var(--ease) 0.4s forwards;
  }
  #shopify-section-{{ section.id }} .collection-card[data-card="2"].is-entering {
    animation: card-in-right 0.9s var(--ease) 0.6s forwards;
  }

  /* 3D hover lift */
  #shopify-section-{{ section.id }} .collection-card:hover {
    transform: rotateX(var(--ry, 0deg)) rotateY(var(--rx, 0deg)) translateZ(18px);
    box-shadow: 0 30px 60px rgba(0,0,0,0.45);
  }

  /* Background tint */
  #shopify-section-{{ section.id }} .collection-card::before {
    content: "";
    position: absolute;
    inset: 0;
    opacity: 0.6;
    transition: opacity 0.5s var(--ease);
    z-index: 0;
  }
  #shopify-section-{{ section.id }} .collection-card:hover::before {
    opacity: 1;
  }

  /* Mouse spotlight */
  #shopify-section-{{ section.id }} .collection-card::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0;
    transition: opacity 0.4s var(--ease);
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .collection-card:hover::after {
    opacity: 1;
  }

  /* ============================================================
     Full Card Image
     ============================================================ */
  #shopify-section-{{ section.id }} .card-bottle-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
    padding: 0;
    min-height: 0;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .card-bottle-img {
    width: 100%;
    height: 100%;
    max-width: 100%;
    aspect-ratio: auto;
    opacity: 0.8;
    transform: scale(1.1);
    position: relative;
  }

  #shopify-section-{{ section.id }} .card-bottle-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.5) saturate(0.9);
    transition: filter 0.6s var(--ease), transform 0.6s var(--ease);
    display: block;
  }

  #shopify-section-{{ section.id }} .collection-card:hover .card-bottle-img img {
    filter: brightness(0.65) saturate(1.1);
    transform: scale(1.05);
  }

  #shopify-section-{{ section.id }} .card-bottle-img .bottle-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a1a1a, #0a0a0a);
  }

  /* Hide bottle glow for full image */
  #shopify-section-{{ section.id }} .card-bottle-glow {
    display: none;
  }

  /* ============================================================
     Card Content Overlay
     ============================================================ */
  #shopify-section-{{ section.id }} .collection-card .card-content {
    position: relative;
    z-index: 1;
    margin-top: auto;
    padding: 40px 36px 40px;
    background: linear-gradient(
      to top, 
      rgba(0,0,0,0.85) 0%,
      rgba(0,0,0,0.3) 40%,
      transparent 100%
    );
    transition: background 0.4s var(--ease);
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .collection-card:hover .card-content {
    background: linear-gradient(
      to top, 
      rgba(0,0,0,0.9) 0%,
      rgba(0,0,0,0.4) 40%,
      transparent 100%
    );
  }

  /* Floating number */
  #shopify-section-{{ section.id }} .collection-num {
    position: absolute;
    top: 30px;
    left: 30px;
    z-index: 2;
    font-family: var(--font-display);
    font-size: 14px;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.4);
    animation: num-float 3.5s ease-in-out infinite;
    animation-delay: var(--float-delay, 0s);
  }

  /* Text elements */
  #shopify-section-{{ section.id }} .collection-tier {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    margin-bottom: 10px;
    position: relative;
    z-index: 1;
    transition: color 0.3s var(--ease), transform 0.45s var(--ease), opacity 0.45s var(--ease);
    transition-delay: 0s;
  }

  #shopify-section-{{ section.id }} .collection-card:hover .collection-tier {
    color: rgba(255,255,255,0.8);
    transition-delay: 0.04s;
  }

  #shopify-section-{{ section.id }} .collection-card h3 {
    margin-bottom: 10px;
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    font-size: clamp(26px, 2.8vw, 34px);
    font-weight: 400;
    letter-spacing: 0.01em;
    line-height: 1.05;
    color: #ffffff;
    transition: letter-spacing 0.5s var(--ease), transform 0.45s var(--ease), opacity 0.45s var(--ease);
    transition-delay: 0s;
  }

  #shopify-section-{{ section.id }} .collection-card:hover h3 {
    letter-spacing: 0.03em;
    transition-delay: 0.08s;
  }

  #shopify-section-{{ section.id }} .collection-card p {
    max-width: 300px;
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
    color: rgba(255,255,255,0.7);
    line-height: 1.7;
    font-size: 14px;
    transition: transform 0.45s var(--ease), opacity 0.45s var(--ease), color 0.3s var(--ease);
    transition-delay: 0s;
  }

  #shopify-section-{{ section.id }} .collection-card:hover p {
    color: rgba(255,255,255,0.85);
    transition-delay: 0.12s;
  }

  #shopify-section-{{ section.id }} .collection-price {
    font-family: var(--font-display);
    font-size: 18px;
    margin-bottom: 18px;
    position: relative;
    z-index: 1;
    color: {{ accent_color }};
    transition: transform 0.45s var(--ease), opacity 0.45s var(--ease);
    transition-delay: 0s;
  }

  #shopify-section-{{ section.id }} .collection-card:hover .collection-price {
    transition-delay: 0.16s;
  }

  #shopify-section-{{ section.id }} .collection-link {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    position: relative;
    z-index: 1;
    width: fit-content;
    padding-bottom: 4px;
    border-bottom: 1px solid rgba(198,165,107,0.3);
    color: {{ accent_color }};
    transition: border-color 0.3s var(--ease), transform 0.45s var(--ease), opacity 0.45s var(--ease);
    transition-delay: 0s;
  }

  #shopify-section-{{ section.id }} .collection-card:hover .collection-link {
    border-color: {{ accent_color }};
    transition-delay: 0.2s;
  }

  #shopify-section-{{ section.id }} .collection-link svg {
    width: 14px;
    height: 14px;
    transition: transform 0.35s var(--ease);
  }

  #shopify-section-{{ section.id }} .collection-card:hover .collection-link svg {
    transform: translateX(6px);
  }

  /* Hover stagger rise on all text elements */
  #shopify-section-{{ section.id }} .collection-card:hover .collection-tier,
  #shopify-section-{{ section.id }} .collection-card:hover h3,
  #shopify-section-{{ section.id }} .collection-card:hover p,
  #shopify-section-{{ section.id }} .collection-card:hover .collection-price,
  #shopify-section-{{ section.id }} .collection-card:hover .collection-link {
    animation: elem-rise 0.5s var(--ease) both;
  }

  /* ============================================================
     Border Lines & Shimmer
     ============================================================ */
  #shopify-section-{{ section.id }} .card-shimmer {
    position: absolute;
    top: 0; left: 0;
    width: 50%; height: 100%;
    background: linear-gradient(105deg, transparent 30%, rgba(255,255,255,0.04) 45%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.04) 55%, transparent 70%);
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transform: translateX(-120%) skewX(-15deg);
  }

  #shopify-section-{{ section.id }} .collection-card:hover .card-shimmer {
    animation: shimmer 0.9s var(--ease) 0.15s forwards;
  }

  #shopify-section-{{ section.id }} .card-border-top,
  #shopify-section-{{ section.id }} .card-border-bottom {
    position: absolute;
    left: 0; width: 100%; height: 1px;
    z-index: 2;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .card-border-top {
    top: 0;
    background: linear-gradient(90deg, transparent, {{ accent_color }}50, transparent);
    transform: scaleX(0);
  }

  #shopify-section-{{ section.id }} .card-border-bottom {
    bottom: 0;
    background: linear-gradient(90deg, transparent, {{ accent_color }}50, transparent);
    transform: scaleX(0);
  }

  #shopify-section-{{ section.id }} .collection-card:hover .card-border-top {
    animation: line-draw-top 0.6s var(--ease) 0.05s forwards;
  }

  #shopify-section-{{ section.id }} .collection-card:hover .card-border-bottom {
    animation: line-draw-bottom 0.6s var(--ease) 0.15s forwards;
  }

  /* Signature breathing */
  #shopify-section-{{ section.id }} .collection-card.is-signature.is-entered {
    animation: sig-breathe 4s ease-in-out infinite;
  }

  #shopify-section-{{ section.id }} .collection-card.is-signature.is-entered:hover {
    animation: none;
    box-shadow: 0 30px 60px rgba(0,0,0,0.45), inset 0 0 100px rgba(198,165,107,0.08);
  }

  /* ============================================================
     Disable 3D on touch / small
     ============================================================ */
  @media (max-width: 900px), (hover: none) {
    #shopify-section-{{ section.id }} .collection-card {
      transform: none !important;
    }
    #shopify-section-{{ section.id }} .collection-card:hover {
      transform: none !important;
      box-shadow: none;
    }
    #shopify-section-{{ section.id }} .collection-card.is-signature.is-entered {
      animation: none;
    }
    #shopify-section-{{ section.id }} .collection-card:hover .card-bottle-img img {
      transform: scale(1.02);
    }
  }

  /* ============================================================
     Mobile
     ============================================================ */
  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .collections-grid {
      grid-template-columns: 1fr;
    }
    
    #shopify-section-{{ section.id }} .collection-card,
    #shopify-section-{{ section.id }} .collection-card.is-signature {
      min-height: 500px;
    }
    
    #shopify-section-{{ section.id }} .collection-card.is-signature {
      min-height: 550px;
    }
    
    #shopify-section-{{ section.id }} .collection-card .card-content {
      padding: 30px 24px 30px;
    }
    
    #shopify-section-{{ section.id }} .collection-num {
      top: 20px;
      left: 20px;
    }
    
    #shopify-section-{{ section.id }} .collection-card[data-card="0"].is-entering,
    #shopify-section-{{ section.id }} .collection-card[data-card="1"].is-entering,
    #shopify-section-{{ section.id }} .collection-card[data-card="2"].is-entering {
      animation: card-in-up 0.8s var(--ease) forwards;
    }
    
    #shopify-section-{{ section.id }} .collection-card[data-card="1"].is-entering {
      animation-delay: 0.15s;
    }
    
    #shopify-section-{{ section.id }} .collection-card[data-card="2"].is-entering {
      animation-delay: 0.3s;
    }
  }

  @media (max-width: 480px) {
    #shopify-section-{{ section.id }} .collections-section {
      padding: 60px 0;
    }
    
    #shopify-section-{{ section.id }} .collection-card {
      min-height: 420px;
    }
    
    #shopify-section-{{ section.id }} .collection-card.is-signature {
      min-height: 460px;
    }
    
    #shopify-section-{{ section.id }} .collection-card .card-content {
      padding: 24px 20px 24px;
    }
    
    #shopify-section-{{ section.id }} .collection-card p {
      font-size: 13px;
      margin-bottom: 12px;
    }
    
    #shopify-section-{{ section.id }} .collection-card h3 {
      font-size: 22px;
    }
    
    #shopify-section-{{ section.id }} .collection-price {
      font-size: 16px;
      margin-bottom: 14px;
    }
  }
</style>

<div class="collections-section" id="collections-section-{{ section.id }}">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="eyebrow" id="eyebrow-{{ section.id }}">{{ subheading }}</span>
        <h2 id="heading-{{ section.id }}">{{ heading }}</h2>
      </div>
      {% if section.settings.show_view_all %}
        <a href="{{ section.settings.view_all_link | default: '/collections/all' }}" class="view-all" id="viewall-{{ section.id }}">{{ section.settings.view_all_text | default: 'View All' }}</a>
      {% endif %}
    </div>
  </div>
  <div class="container">
    <div class="collections-grid" id="grid-{{ section.id }}">

      {%- comment -%} CARD 1 {%- endcomment -%}
      <a href="{% if collection_1 %}{% if request.path contains '/collections/' %}{{ routes.root_url }}{% endif %}/collections/{{ collection_1.handle }}{% else %}#{% endif %}" class="collection-card{% if collection_1_is_signature %} is-signature{% endif %}" style="--rx: 0deg; --ry: 0deg; --mx: 49.3%; --my: 94.8%;" data-card="0">
        <span class="collection-num">01</span>
        <div class="card-bottle-wrap">
          <div class="card-bottle-img">
            {% if image_1 %}
              {% assign image_url_1 = image_1 | image_url: width: 800 %}
              <img src="{{ image_url_1 }}" alt="{{ collection_1.title | default: 'Classic' }}" loading="lazy" width="800" height="1000">
            {% else %}
              <div class="bottle-placeholder"></div>
            {% endif %}
          </div>
        </div>
        <div class="card-content">
          <span class="collection-tier">{{ collection_1_tier }}</span>
          <h3>{{ collection_1.title | default: 'Classic' }}</h3>
          <p>{{ collection_1_tagline }}</p>
          <span class="collection-price">{{ collection_1_price }}</span>
          <span class="collection-link">{{ button_text }} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 5l7 7-7 7"></path></svg></span>
        </div>
        <span class="card-shimmer"></span>
        <span class="card-border-top"></span>
        <span class="card-border-bottom"></span>
      </a>

      {%- comment -%} CARD 2 (Signature) {%- endcomment -%}
      <a href="{% if collection_2 %}{% if request.path contains '/collections/' %}{{ routes.root_url }}{% endif %}/collections/{{ collection_2.handle }}{% else %}#{% endif %}" class="collection-card is-signature" style="--card-tint: radial-gradient(circle at 50% 15%, rgba(198,165,107,0.12), transparent 65%); --rx: 0deg; --ry: 0deg; --mx: 0.3%; --my: 53.8%;" data-card="1">
        <span class="collection-num">02</span>
        <div class="card-bottle-wrap">
          <div class="card-bottle-img">
            {% if image_2 %}
              {% assign image_url_2 = image_2 | image_url: width: 800 %}
              <img src="{{ image_url_2 }}" alt="{{ collection_2.title | default: 'Signature' }}" loading="lazy" width="800" height="1000">
            {% else %}
              <div class="bottle-placeholder"></div>
            {% endif %}
          </div>
        </div>
        <div class="card-content">
          <span class="collection-tier">{{ collection_2_tier }}</span>
          <h3>{{ collection_2.title | default: 'Signature' }}</h3>
          <p>{{ collection_2_tagline }}</p>
          <span class="collection-price">{{ collection_2_price }}</span>
          <span class="collection-link">{{ button_text }} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 5l7 7-7 7"></path></svg></span>
        </div>
        <span class="card-shimmer"></span>
        <span class="card-border-top"></span>
        <span class="card-border-bottom"></span>
      </a>

      {%- comment -%} CARD 3 {%- endcomment -%}
      <a href="{% if collection_3 %}{% if request.path contains '/collections/' %}{{ routes.root_url }}{% endif %}/collections/{{ collection_3.handle }}{% else %}#{% endif %}" class="collection-card{% if collection_3_is_signature %} is-signature{% endif %}" style="--rx: 0deg; --ry: 0deg; --mx: 4.6%; --my: 0.8%;" data-card="2">
        <span class="collection-num">03</span>
        <div class="card-bottle-wrap">
          <div class="card-bottle-img">
            {% if image_3 %}
              {% assign image_url_3 = image_3 | image_url: width: 800 %}
              <img src="{{ image_url_3 }}" alt="{{ collection_3.title | default: 'Inspired' }}" loading="lazy" width="800" height="1000">
            {% else %}
              <div class="bottle-placeholder"></div>
            {% endif %}
          </div>
        </div>
        <div class="card-content">
          <span class="collection-tier">{{ collection_3_tier }}</span>
          <h3>{{ collection_3.title | default: 'Inspired' }}</h3>
          <p>{{ collection_3_tagline }}</p>
          <span class="collection-price">{{ collection_3_price }}</span>
          <span class="collection-link">{{ button_text }} <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 5l7 7-7 7"></path></svg></span>
        </div>
        <span class="card-shimmer"></span>
        <span class="card-border-top"></span>
        <span class="card-border-bottom"></span>
      </a>

    </div>
  </div>
</div>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var section = document.getElementById('collections-section-' + sectionId);
    if (!section) return;

    var head = section.querySelector('.section-head');
    var heading = document.getElementById('heading-' + sectionId);
    var cards = section.querySelectorAll('.collection-card');
    var hasAnimated = false;

    /* Wrap heading words */
    function wrapWords(el) {
      var text = el.textContent.trim();
      var words = text.split(/\s+/);
      el.innerHTML = words.map(function(w, i) {
        return '<span class="word"><span class="word-inner" style="animation-delay:' + (0.15 + i * 0.08) + 's">' + w + '</span></span> ';
      }).join('');
    }
    if (heading) wrapWords(heading);

    /* Stagger float delays */
    cards.forEach(function(card, i) {
      var num = card.querySelector('.collection-num');
      if (num) num.style.setProperty('--float-delay', (i * 1.1) + 's');
    });

    /* Intersection Observer */
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && !hasAnimated) {
          hasAnimated = true;
          if (head) head.classList.add('is-visible');

          cards.forEach(function(card, i) {
            card.classList.add('is-entering');
            card.addEventListener('animationend', function onEnd(e) {
              if (e.animationName.indexOf('card-in') !== -1) {
                card.classList.remove('is-entering');
                card.style.opacity = '1';
                if (card.classList.contains('is-signature')) {
                  card.classList.add('is-entered');
                }
                card.removeEventListener('animationend', onEnd);
              }
            });
          });

          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    observer.observe(section);

    /* 3D Tilt + Spotlight */
    var isTouch = 'ontouchstart' in window || navigator.maxTouchPoints > 0;

    cards.forEach(function(card) {
      if (isTouch || window.innerWidth <= 900) return;

      card.addEventListener('mousemove', function(e) {
        var rect = card.getBoundingClientRect();
        var x = e.clientX - rect.left;
        var y = e.clientY - rect.top;
        var centerX = rect.width / 2;
        var centerY = rect.height / 2;

        var rotateY = ((x - centerX) / centerX) * 5;
        var rotateX = ((centerY - y) / centerY) * 5;

        card.style.setProperty('--rx', rotateY + 'deg');
        card.style.setProperty('--ry', rotateX + 'deg');
        card.style.setProperty('--mx', ((x / rect.width) * 100) + '%');
        card.style.setProperty('--my', ((y / rect.height) * 100) + '%');
      });

      card.addEventListener('mouseleave', function() {
        card.style.setProperty('--rx', '0deg');
        card.style.setProperty('--ry', '0deg');
      });
    });
  })();
</script>

