<nav class="nav">
  <div class="nav-inner" style="justify-content: center;">
    <a href="{{ routes.root_url }}" class="nav-logo">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="100" height="28">
      {%- else -%}
        {{ shop.name }}
      {%- endif -%}
    </a>
  </div>
</nav>

{% schema %}
{
  "name": "Password header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    }
  ]
}
{% endschema %}
