{%- comment -%}
  Renders breadcrumb trail.
  Usage: {% render 'breadcrumbs' %}
  Automatically builds trail based on current template/page type.
{%- endcomment -%}

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <a href="{{ routes.root_url }}">Home</a>

  {%- case request.page_type -%}
    {%- when 'product' -%}
      <span class="sep">/</span>
      <a href="{{ routes.all_products_collection_url }}">Collection</a>
      {%- if collection -%}
        <span class="sep">/</span>
        <a href="{{ collection.url }}">{{ collection.title }}</a>
      {%- endif -%}
      <span class="sep">/</span>
      <span>{{ product.title }}</span>

    {%- when 'collection' -%}
      <span class="sep">/</span>
      <a href="{{ routes.all_products_collection_url }}">Collection</a>
      {%- if current_tags -%}
        <span class="sep">/</span>
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <span class="sep">/</span>
        <span>{{ current_tags | join: ', ' }}</span>
      {%- else -%}
        <span class="sep">/</span>
        <span>{{ collection.title }}</span>
      {%- endif -%}

    {%- when 'page' -%}
      <span class="sep">/</span>
      <span>{{ page.title }}</span>

    {%- when 'blog' -%}
      <span class="sep">/</span>
      <span>{{ blog.title }}</span>

    {%- when 'article' -%}
      <span class="sep">/</span>
      <a href="{{ blog.url }}">{{ blog.title }}</a>
      <span class="sep">/</span>
      <span>{{ article.title }}</span>
  {%- endcase -%}
</nav>
