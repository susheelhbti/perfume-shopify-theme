<div class="password-page">
  <div class="password-inner">
    <a href="{{ routes.root_url }}" class="nav-logo password-logo">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 240 }}" alt="{{ shop.name }}" width="120" height="38">
      {%- else -%}
        {{ shop.name }}
      {%- endif -%}
    </a>

    <span class="eyebrow">{%- if section.settings.eyebrow != blank -%}{{ section.settings.eyebrow }}{%- else -%}Coming Soon{%- endif -%}</span>
    <h1 class="password-heading">{{ section.settings.heading | default: shop.name }}</h1>
    <p class="password-body">{{ section.settings.body | default: "Rare attars and perfume oils, distilled from centuries-old traditions. We're putting the final touches on something special." }}</p>

    {%- if shop.password_message != blank -%}
      <div class="legal-section" style="text-align: left; margin-top: 1rem;">{{ shop.password_message }}</div>
    {%- endif -%}

    {%- if section.settings.show_newsletter -%}
      <form class="newsletter-input-group" data-newsletter-form style="margin: 2rem auto 0;">
        <input type="email" name="email" placeholder="Be the first to know" required>
        <button type="submit">Notify Me</button>
      </form>
      <p class="newsletter-success">Thank you — we'll be in touch.</p>
      <p class="newsletter-error"></p>
    {%- endif -%}

    {%- if shop.password_used_for_storefront_access_token == false -%}
      <a href="{{ routes.account_login_url }}" class="password-admin-link">Store owner login</a>
    {%- endif -%}

    {% render 'social-icons' %}
  </div>
</div>

{% schema %}
{
  "name": "Password page",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Coming Soon"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Rare attars and perfume oils, distilled from centuries-old traditions. We're putting the final touches on something special."
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show notify-me form",
      "default": true
    }
  ]
}
{% endschema %}
