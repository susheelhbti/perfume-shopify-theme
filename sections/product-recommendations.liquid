<section class="pd-related-section" id="product-recommendations" data-recommendations
     data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_to_show }}&intent={{ section.settings.intent }}">

  <div class="container">
    {%- if recommendations.performed and recommendations.products_count > 0 -%}
      <div class="pd-related">
        <h3>{{ section.settings.heading }}</h3>
        <div class="product-grid cols-3">
          {%- for related_product in recommendations.products -%}
            {% render 'product-card', product: related_product %}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    var section = document.currentScript.closest('[data-recommendations]') || document.getElementById('product-recommendations');
    if (!section) return;
    var url = section.getAttribute('data-url');
    if (!url) return;

    fetch(url)
      .then(function (res) { return res.text(); })
      .then(function (html) {
        var parser = new DOMParser();
        var doc = parser.parseFromString(html, 'text/html');
        var newContent = doc.querySelector('[data-recommendations]');
        if (newContent && newContent.innerHTML.trim() !== '') {
          section.innerHTML = newContent.innerHTML;
        }
      })
      .catch(function () {});
  })();
</script>

{% schema %}
{
  "name": "Product recommendations",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "intent",
      "label": "Recommendation intent",
      "options": [
        { "value": "related", "label": "Related" },
        { "value": "complementary", "label": "Complementary" }
      ],
      "default": "related"
    }
  ]
}
{% endschema %}
